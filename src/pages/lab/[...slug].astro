---
import path from 'node:path';
import {findRepoRoot} from '@/lib/ecosystem.mjs';
import {loadLabPages} from '@/lib/lab/load-lab.mjs';
import {getPortalContext} from '@/lib/portal.mjs';
import PortalLayout from '@/components/PortalLayout.astro';
import PortalSidebar from '@/components/PortalSidebar.astro';
import ArticleBreadcrumbs from '@/components/ArticleBreadcrumbs.astro';
import ArticleToolbar from '@/components/ArticleToolbar.astro';
import ArticleToc from '@/components/ArticleToc.astro';

export async function getStaticPaths() {
  const contentDir = path.join(findRepoRoot(), 'content/lab');
  const lab = await loadLabPages(contentDir);
  return lab.pages.map((page) => ({
    params: {slug: page.pathSlug},
    props: {page, sidebar: lab.sidebar},
  }));
}

const {page, sidebar} = Astro.props;
const {navItems, brandHref, brandLabel, ecosystemConfigJson} = getPortalContext();

const sidebarItems = sidebar.map((item) => {
  if (item.type === 'category') {
    const childActive = item.children.some((child) => child.href === page.href);
    return {
      ...item,
      active: item.href === page.href,
      open: childActive || item.href === page.href || page.categoryLabel === item.label,
      children: item.children.map((child) => ({
        ...child,
        active: child.href === page.href,
      })),
    };
  }
  return {...item, active: item.href === page.href};
});
---

<PortalLayout
  title={`${page.title} — Лаборатория IT Universe`}
  description={page.description || 'Практика и тренажёры Вселенная IT'}
  brandLabel={brandLabel}
  brandHref={brandHref}
  navItems={navItems}
  hasSidebar={true}
  hasToc={page.toc.length > 1}
  ecosystemConfigJson={ecosystemConfigJson}
>
  <PortalSidebar slot="sidebar" title="Разделы" items={sidebarItems} />

  <ArticleBreadcrumbs items={page.breadcrumbs} />

  <header class="portal-hero">
    <h1>{page.title}</h1>
    {page.description ? <p>{page.description}</p> : null}
  </header>

  <ArticleToolbar title={page.title} href={page.href} />

  <div class="article-layout">
    <article class="article-shell">
      <div class="article-body" set:html={page.bodyHtml} />
    </article>
    <ArticleToc items={page.toc} />
  </div>

  {
    page.relatedLinks.length > 0 ? (
      <aside class="related-topics" aria-label="Связанные темы">
        <h2>Связанные темы</h2>
        <ul>
          {page.relatedLinks.map((link) => (
            <li>
              <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener noreferrer' : undefined}>
                {link.title}
                {link.external ? ' ↗' : ''}
              </a>
            </li>
          ))}
        </ul>
      </aside>
    ) : null
  }

</PortalLayout>
