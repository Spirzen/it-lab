---
import PortalLayout from '@/components/PortalLayout.astro';
import {getPortalContext} from '@/lib/portal.mjs';

const {navItems, brandHref, brandLabel, ecosystemConfigJson} = getPortalContext();
---

<PortalLayout
  title="Лаборатория — IT Universe"
  description="lab.spirzen.ru — практика и тренажёры"
  brandLabel={brandLabel}
  brandHref={brandHref}
  navItems={navItems}
  ecosystemConfigJson={ecosystemConfigJson}
>
  <div class="portal-hero">
    <h1>Лаборатория</h1>
    <p>Контент из <code>docs/lab</code> энциклопедии. Префикс <code>/lab/</code>.</p>
  </div>
  <div class="placeholder-card">
    <h2>В разработке</h2>
    <p>Репозиторий <code>it-lab</code> · <code>lab.spirzen.ru</code></p>
  </div>
</PortalLayout>
